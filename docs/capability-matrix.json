{
  "version": "2026-04-09",
  "brandName": "Annona",
  "category": "decision_intelligence_for_operations",
  "corePromise": "See clearly. Act early.",
  "canonicalSpec": "docs/annona-engine-spec.md",
  "architecture": {
    "uiContainer": {
      "name": "annona-ui",
      "responsibilities": [
        "authentication gate",
        "prompt submission",
        "trace and answer rendering"
      ]
    },
    "engineContainer": {
      "name": "annona-engine",
      "responsibilities": [
        "dataset intake",
        "schema interpretation",
        "dataset compilation",
        "capability registry and binding",
        "planning and orchestration",
        "tool execution",
        "evaluation",
        "translation and narration",
        "answer composition"
      ]
    },
    "optionalWorkers": [
      "forecasting jobs",
      "optimization jobs",
      "automl jobs"
    ]
  },
  "layerModel": [
    {
      "id": "layer_1_schema_interpreter",
      "name": "Universal Schema Interpreter",
      "role": "foundational_compile_step"
    },
    {
      "id": "layer_2_tool_substrate",
      "name": "Universal Analytical Toolkit",
      "role": "default_capability_registry_foundation"
    },
    {
      "id": "layer_3_annona_orchestration",
      "name": "Annona orchestration and recommendation layer",
      "role": "planning_evaluation_and_operator_framing"
    }
  ],
  "sharedBaseline": {
    "description": "Both panels begin from the same tabular-data baseline and the same native web and code surface.",
    "data": [
      "uploaded CSV / tabular datasets",
      "canonical bundled fixture used as the upload surrogate in tests",
      "canonical manufacturing dependency bundle with BOM, work-order, and purchase-order tables compiled into a graph trace",
      "canonical Zeder shadow progress snapshot used to model Virtual MES / Shadow Factory status over broken ERP / MRP data"
    ],
    "nativeProviderTools": [
      "web_search",
      "code_sandbox",
      "tabular_file_search"
    ],
    "truthConstraints": [
      "No live ERP or warehouse connection is implied unless explicitly configured.",
      "Shared baseline access is the same for both panels.",
      "Web findings must stay distinct from dataset findings."
    ]
  },
  "leftAgent": {
    "id": "raw",
    "name": "Ungrounded / Raw Agent",
    "inheritsSharedBaseline": true,
    "role": "generic_model_over_shared_baseline",
    "strengths": [
      "direct file inspection",
      "generic calculations",
      "web lookups when available"
    ],
    "constraints": [
      "No Annona orchestration layer",
      "No dataset-adaptive planning contract",
      "No explicit answer-evaluation pass before final response"
    ]
  },
  "rightAgent": {
    "id": "grounded",
    "name": "Grounded Annona Agent",
    "inheritsSharedBaseline": true,
    "role": "dataset_adaptive_orchestrator",
    "differentiators": [
      "layer_1_schema_interpreter",
      "stable analysis primitives",
      "capability-template binding",
      "orchestration and answer planning",
      "answer evaluation before response",
      "translation and narration layer"
    ],
    "outputContract": [
      "clear recommendation with context",
      "situation_impact_action structure when a decision is required",
      "explainable and traceable reasoning",
      "estimated states explicitly labeled when point-of-use truth is missing",
      "no dashboard sprawl or black-box claims"
    ]
  },
  "universalToolkit": {
    "name": "Universal Analytical Toolkit",
    "compositionRule": "tools_are_independently_invocable_and_composable_not_a_mandatory_pipeline",
    "defaultSubstrateTools": [
      "profile",
      "correlate",
      "anomaly",
      "regress",
      "segment",
      "forecast",
      "classify",
      "simulate",
      "optimize",
      "narrate"
    ]
  },
  "annonaFlow": {
    "stages": [
      {
        "id": "schema_interpretation",
        "label": "Universal Schema Interpreter",
        "outcome": "Compile arbitrary tabular inputs into a reusable dataset profile and semantic model."
      },
      {
        "id": "capability_binding",
        "label": "Capability binding",
        "outcome": "Bind universal substrate tools and Annona-specific templates to dataset-specific tools with resolved fields, grains, and constraints."
      },
      {
        "id": "analysis_primitives",
        "label": "Stable analysis primitives",
        "outcome": "Prefer reusable primitives like variance, ranking, thresholding, forecasting, optimization framing, and recommendation synthesis over ad hoc tool invention."
      },
      {
        "id": "orchestration_planning",
        "label": "Orchestration and planning",
        "outcome": "Select the minimum effective set of independently invocable tools for the prompt."
      },
      {
        "id": "answer_evaluation",
        "label": "Answer evaluation",
        "outcome": "Check whether the recommendation is supported, scoped, operationally usable, and correctly calibrated between observed and estimated state before finalizing it."
      },
      {
        "id": "translation_narration",
        "label": "Translation and narration",
        "outcome": "Turn structured analytical outputs into operator-readable explanation without inventing unsupported facts."
      }
    ],
    "stableAnalysisPrimitives": [
      "dataset profiling",
      "schema-to-meaning mapping",
      "margin decomposition",
      "variance ranking",
      "service-risk ranking",
      "future-state risk framing",
      "dependency graph compilation",
      "multi-hop dependency tracing",
      "impact propagation across shared components",
      "inferred progress heuristics",
      "probabilistic traceability",
      "wobble detection",
      "virtual MES / shadow factory status synthesis",
      "management-status mapping",
      "recommendation synthesis",
      "answer self-check"
    ],
    "traceabilityModel": {
      "exactMode": "Use exact traceability only when point-of-use confirmation exists.",
      "probabilisticMode": "When point-of-use confirmation is missing, infer progress from shadow signals and label the result as estimated.",
      "requiredOutputs": [
        "traceability_mode",
        "point_of_use_data_status",
        "management_status",
        "estimated_state",
        "progress_pct_low",
        "inferred_progress_pct",
        "progress_pct_high",
        "evidence_coverage_pct",
        "wobble_detected",
        "caveats"
      ],
      "wobbleSignals": [
        "eta_regression",
        "quantity_reversal",
        "stall_after_forward_progress",
        "conflicting_adjacent_system_signals"
      ]
    },
    "virtualMesShadowFactoryModel": {
      "productDefinition": "management_facing_visibility_layer_over_broken_erp_mrp_data",
      "systemRole": "compile_directional_factory_state_from_shadow_signals_without_claiming_exact_mes_truth",
      "sourceSystems": [
        "erp_or_mrp_status_snapshots",
        "work_order_and_purchase_order_extracts",
        "dispatch_and_handoff_events",
        "carrier_eta_updates",
        "booking_or_schedule_commits",
        "exception_reopen_or_rework_signals"
      ],
      "coreEntities": {
        "demand": [
          "customers",
          "sales_orders",
          "sales_order_lines"
        ],
        "execution": [
          "kits",
          "work_orders",
          "operation_steps",
          "machines",
          "work_centers",
          "factories"
        ],
        "supply": [
          "parts",
          "assemblies",
          "bom_edges",
          "purchase_orders",
          "purchase_order_lines",
          "inventory_positions"
        ],
        "signals": [
          "erp_or_mrp_status_snapshot",
          "dispatch_or_handoff_event",
          "carrier_eta_event",
          "booking_or_schedule_commitment",
          "quantity_acknowledgement",
          "exception_reopen_or_rework_event"
        ]
      },
      "inferredExecutionStates": [
        "queued_not_started",
        "material_constrained",
        "ready_to_build",
        "in_build",
        "built_pending_handoff",
        "in_transit",
        "arrived_at_site_not_confirmed_at_point_of_use",
        "installed_not_confirmed",
        "blocked_on_dependency",
        "exception_or_rework"
      ],
      "managementStatuses": [
        {
          "id": "on_track",
          "meaning": "forward motion is visible and no active blocker or wobble is present"
        },
        {
          "id": "watch",
          "meaning": "directional progress exists but confidence or schedule slack is thinning"
        },
        {
          "id": "verify_now",
          "meaning": "conflicting signals make the apparent progress unsafe to commit without manual confirmation"
        },
        {
          "id": "blocked",
          "meaning": "a dependency or execution constraint is preventing the next operational step"
        }
      ],
      "requiredOutputs": [
        "entity_type",
        "entity_id",
        "virtual_mes_mode",
        "traceability_mode",
        "management_status",
        "estimated_state",
        "primary_constraint",
        "status_reason",
        "inferred_progress_pct",
        "progress_pct_low",
        "progress_pct_high",
        "evidence_coverage_pct",
        "wobble_detected",
        "supporting_signals",
        "counter_signals",
        "recommended_action",
        "caveats"
      ]
    },
    "dependencyGraphModel": {
      "entities": [
        "parts",
        "assemblies",
        "bom_levels",
        "sales_orders",
        "sales_order_lines",
        "work_orders",
        "purchase_orders",
        "purchase_order_lines",
        "customers",
        "machines",
        "factories"
      ],
      "edgeTypes": [
        "sales_order_to_line",
        "line_to_root_work_order",
        "work_order_to_child_work_order",
        "work_order_to_bom_component",
        "component_to_purchase_order_line",
        "purchase_order_line_to_purchase_order",
        "work_order_to_machine",
        "work_order_to_factory",
        "sales_order_to_customer"
      ],
      "requiredOutputs": [
        "root_entity_type",
        "root_entity_id",
        "critical_path",
        "path_hops",
        "blocker_part_id",
        "blocker_purchase_order_id",
        "impacted_sales_orders",
        "impacted_work_orders"
      ]
    }
  },
  "registry": {
    "model": "capability_template_registry_with_dataset_adaptive_binding",
    "bindingTime": "compile_once_per_dataset_version",
    "foundation": "universal_analytical_toolkit",
    "requiredTemplateFields": [
      "capabilityId",
      "family",
      "schemaVersion",
      "intentClasses",
      "datasetPreconditions",
      "requiredSemanticRoles",
      "parameterSchema",
      "artifactOutputs",
      "evidenceOutputs",
      "runtimeCostClass",
      "executionMode",
      "policyConstraints"
    ]
  },
  "algorithmicFamilies": [
    {
      "id": "descriptive_analysis",
      "substrateTools": [
        "profile",
        "segment"
      ],
      "examples": [
        "summary_statistics",
        "grouped_rollups",
        "ranking",
        "segmentation",
        "trend_extraction",
        "cohort_and_mix_analysis"
      ]
    },
    {
      "id": "driver_diagnostic_analysis",
      "substrateTools": [
        "correlate",
        "regress"
      ],
      "examples": [
        "variance_decomposition",
        "contribution_analysis",
        "segment_comparison",
        "change_point_explanation",
        "driver_modeling"
      ]
    },
    {
      "id": "anomaly_detection",
      "substrateTools": [
        "anomaly"
      ],
      "examples": [
        "threshold_rules",
        "robust_z_score",
        "residual_scan",
        "peer_group_deviation",
        "sequence_break_detection"
      ]
    },
    {
      "id": "forecasting",
      "substrateTools": [
        "forecast"
      ],
      "examples": [
        "univariate_baseline_forecast",
        "hierarchical_forecast",
        "scenario_delta_projection",
        "capacity_gap_forecast"
      ]
    },
    {
      "id": "optimization_prescriptive_logic",
      "substrateTools": [
        "simulate",
        "optimize"
      ],
      "examples": [
        "rule_based_action_selection",
        "constrained_prioritization",
        "resource_allocation_heuristics",
        "mathematical_optimization"
      ]
    },
    {
      "id": "classification",
      "substrateTools": [
        "classify"
      ],
      "examples": [
        "target_labeling",
        "risk_bucket_prediction",
        "segment_assignment"
      ]
    },
    {
      "id": "translation_narration",
      "substrateTools": [
        "narrate"
      ],
      "examples": [
        "operator_ready_explanation",
        "recommendation_wording",
        "assumption_and_confidence_translation"
      ]
    },
    {
      "id": "selective_automl",
      "examples": [
        "predictive_model_search_when_target_and_budget_are_valid"
      ],
      "guardrails": [
        "not default",
        "requires explainability artifacts",
        "must improve a real decision"
      ]
    }
  ],
  "plannerPolicy": {
    "priorityOrder": [
      "reuse_compiled_dataset_assets",
      "use_deterministic_bound_capabilities",
      "use_lightweight_retrieval_over_cached_semantics_and_traces",
      "use_llm_for_refinement_or_synthesis",
      "use_open_ended_code_as_last_resort"
    ],
    "executionModes": [
      "deterministic_only",
      "deterministic_plus_synthesis",
      "model_assisted_planning",
      "async_heavy_compute"
    ],
    "requirements": [
      "require evidence before recommendation",
      "distinguish dataset evidence from web evidence",
      "fail closed on unsupported capability families",
      "downgrade answer confidence when evaluation fails",
      "do_not_force_full_ten_tool_pipeline"
    ]
  },
  "tokenOptimization": {
    "strategy": [
      "compile_once_per_dataset_version",
      "cache_dataset_profile",
      "cache_semantic_model",
      "cache_bound_capabilities",
      "tool_first_llm_last",
      "send_structured_evidence_not_raw_tables"
    ],
    "antiPatterns": [
      "reprofile_same_dataset_every_prompt",
      "inject_raw_csvs_into_model_context",
      "use_llm_to_rediscover_known_field_semantics",
      "force_full_ten_tool_pipeline_for_every_prompt",
      "run_automl_for_simple_descriptive_prompts"
    ]
  },
  "researchHarness": {
    "pilotAutonomousDataTeam": {
      "teamModel": "nine_role_operational_and_data_team",
      "roles": [
        {
          "id": "pilot_pm",
          "name": "Pilot PM",
          "responsibilities": [
            "issue sequencing",
            "acceptance criteria",
            "release gating"
          ],
          "interfaces": [
            "github_issue",
            "canonical_specs",
            "pull_request"
          ],
          "phaseBoundary": {
            "pilot": "human approves scope and release",
            "later": "portfolio planning across multiple pilots"
          }
        },
        {
          "id": "domain_researcher",
          "name": "Domain Researcher",
          "responsibilities": [
            "operator question framing",
            "dataset assumption capture",
            "failure analysis inputs"
          ],
          "interfaces": [
            "demo_acceptance",
            "scenario_fixtures",
            "semantic_notes"
          ],
          "phaseBoundary": {
            "pilot": "shared researcher across one bounded pilot",
            "later": "domain-specific research lanes per vertical"
          }
        },
        {
          "id": "data_pipeline",
          "name": "Data Pipeline",
          "responsibilities": [
            "versioned source intake",
            "freshness checks",
            "compile-ready bundles"
          ],
          "interfaces": [
            "DatasetManifest",
            "storage_refs",
            "ingestion_diagnostics"
          ],
          "phaseBoundary": {
            "pilot": "manual or scheduled extract normalization",
            "later": "automated ingestion and data-quality gating"
          }
        },
        {
          "id": "semantic_modeler",
          "name": "Semantic Modeler",
          "responsibilities": [
            "dataset profile curation",
            "semantic role mapping",
            "compiled helper artifacts"
          ],
          "interfaces": [
            "DatasetProfile",
            "SemanticModel",
            "CompiledDataset"
          ],
          "phaseBoundary": {
            "pilot": "shared schema interpretation and compile ownership",
            "later": "separate interpreter and compiler services"
          }
        },
        {
          "id": "capability_engineer",
          "name": "Capability Engineer",
          "responsibilities": [
            "capability binding",
            "deterministic tool contracts",
            "registry evolution"
          ],
          "interfaces": [
            "CapabilityTemplate",
            "BoundCapability",
            "tool_schemas"
          ],
          "phaseBoundary": {
            "pilot": "single lane can cover multiple capability families",
            "later": "specialized capability and worker-service ownership"
          }
        },
        {
          "id": "orchestration_engineer",
          "name": "Orchestration Engineer",
          "responsibilities": [
            "planner policy",
            "answer scaffolds",
            "confidence posture"
          ],
          "interfaces": [
            "Plan",
            "Recommendation",
            "AnswerEnvelope"
          ],
          "phaseBoundary": {
            "pilot": "bounded planner updates with manual review",
            "later": "separate planner, policy, and answer-quality services"
          }
        },
        {
          "id": "evaluation_qa",
          "name": "Evaluation And QA",
          "responsibilities": [
            "fixture evals",
            "trace review",
            "acceptance gating"
          ],
          "interfaces": [
            "Evaluation",
            "Trace",
            "review_rubrics"
          ],
          "phaseBoundary": {
            "pilot": "human-reviewed eval and smoke gates",
            "later": "continuous eval pipelines and certification lanes"
          }
        },
        {
          "id": "platform_ops",
          "name": "Platform Ops",
          "responsibilities": [
            "environment health",
            "deployment",
            "observability and rollback"
          ],
          "interfaces": [
            "container_images",
            "kubernetes_manifests",
            "smoke_tests"
          ],
          "phaseBoundary": {
            "pilot": "shared platform lane with explicit deploy checks",
            "later": "split platform engineering and SRE/on-call"
          }
        },
        {
          "id": "pilot_ops_analyst",
          "name": "Pilot Ops Analyst",
          "responsibilities": [
            "live trace review",
            "operator feedback capture",
            "next-issue discovery"
          ],
          "interfaces": [
            "live_answer_reviews",
            "failure_analysis_notes",
            "issue_backlog"
          ],
          "phaseBoundary": {
            "pilot": "single feedback loop into the scoped backlog",
            "later": "customer success and pilot-operations functions"
          }
        }
      ],
      "deliveryWorkflow": [
        "issue_scoped_change_on_dedicated_branch_worktree",
        "canonical_spec_update_before_or_with_behavior_change",
        "run_strongest_relevant_validation",
        "open_pull_request_linked_to_issue",
        "deploy_and_smoke_test_before_live_pilot_adoption"
      ]
    },
    "agentTeamLoop": [
      "failure_analysis",
      "plan_changes",
      "modify_scaffold_or_tooling",
      "run_evals",
      "compare_results",
      "keep_or_revert"
    ],
    "iterationTarget": "universal_toolkit_plus_annona_orchestration_per_dataset"
  },
  "schemaFamilies": [
    "DatasetManifest",
    "DatasetProfile",
    "SemanticModel",
    "Artifact",
    "CapabilityTemplate",
    "BoundCapability",
    "Plan",
    "ToolInvocation",
    "Evidence",
    "Recommendation",
    "Evaluation",
    "Trace",
    "AnswerEnvelope"
  ],
  "providerConditions": {
    "openai": {
      "nativeProviderToolsAvailable": true,
      "notes": "Web search, file workflows, and code execution can be part of the shared baseline when OpenAI native tooling is configured."
    },
    "anthropic": {
      "nativeProviderToolsAvailable": false,
      "notes": "Fall back to honest disclosure until equivalent native tooling is wired."
    }
  }
}
